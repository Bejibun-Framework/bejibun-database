{
    "name": "@bejibun/database",
    "version": "0.1.20",
    "author": "Havea Crenata <havea.crenata@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Bejibun-Framework/bejibun-database.git"
    },
    "main": "index.js",
    "module": "index.js",
    "devDependencies": {
        "@types/bun": "latest",
        "tsc-alias": "^1.8.17"
    },
    "bugs": {
        "url": "https://github.com/Bejibun-Framework/bejibun-database/issues"
    },
    "description": "Database for Bejibun Framework",
    "homepage": "https://github.com/Bejibun-Framework/bejibun-database#readme",
    "keywords": [
        "bun",
        "bun framework",
        "database",
        "bejibun",
        "typescript"
    ],
    "license": "MIT",
    "scripts": {
        "alias": "bunx tsc-alias -p tsconfig.json",
        "clean-stubs": "rm -rf stubs",
        "stubs": "cp -rf src/stubs dist",
        "rsync": "rsync -a dist/ ./",
        "clean": "rm -rf dist",
        "build": "bun run clean-stubs && bunx tsc -p tsconfig.json && bun run alias && bun run stubs && bun run rsync && bun run clean",
        "deploy": "bun run build && bun publish --access public"
    },
    "type": "module",
    "types": "index.d.ts",
    "dependencies": {
        "@bejibun/app": "^0.1.23",
        "@bejibun/logger": "^0.1.22",
        "@bejibun/utils": "^0.1.28",
        "knex": "^3.2.10",
        "ora": "^9.4.0",
        "pg": "^8.20.0"
    }
}
